{
  "expo": {
    "name": "ASK VALENTINA",
    "slug": "onspace-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "askvalentina",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      "expo-haptics",
      "expo-image",
      "expo-image-picker",
      "expo-linear-gradient",
      "expo-notifications",
      "expo-device",
      "expo-auth-session",
      "expo-status-bar",
      "expo-secure-store",
      "expo-clipboard",
      "expo-constants",
      "expo-crypto",
      "expo-linking",
      "expo-network",
      "expo-system-ui",
      "@react-native-async-storage/async-storage",
      "react-native-gesture-handler",
      "react-native-reanimated"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
